.El
.Sh EXAMPLES
Get properties of a pool:
.Bd -literal -offset indent
nvpair = require('nvpair')
lzc = require('zfs.core')

lzc.init()
props = lzc.get_props('system')
prop = props:lookup_nvlist('guid')
guid = prop:lookup_uint64('value')
print(('%u'):format(guid))
lzc.fini()
.Ed
.Sh SEE ALSO
.Xr nvpair 3lua
.Sh AUTHORS
.An Ryan Moeller
