.Dd April 25, 2026
.Dt ZFS.CORE 3lua
.Os
.Sh NAME
.Nm zfs.core
.Nd Lua bindings for libzfs_core
.Pq 3
.Sh SYNOPSIS
.Bd -literal
lzc = require('zfs.core')
.Ed
.Pp
.Bl -tag -width XXXX -compact
.It Dv lzc.init( )
.It Dv lzc.fini( )
.It Dv ok_or_errlist, errmsg, errcode = lzc.snapshot(snaps[ , props ] )
.It Dv ok, errmsg, errcode = lzc.create(dsname , type , props[ , wkey ] )
.It Dv ok_or_errsnap, errmsg, errcode = lzc.promote(dsname )
.It Dv ok_or_errlist, errmsg, errcode = lzc.destroy_snaps(snaps[ , defer ] )
.It Dv ok_or_errlist, errmsg, errcode = lzc.bookmark(bookmarks )
.It Dv bookmarks, errmsg, errcode = lzc.get_bookmarks(dsname , props )
.It Dv props, errmsg, errcode = lzc.get_bookmark_props(bookmark )
.It Dv errlist, errmsg, errcode = lzc.destroy_bookmarks(bookmarks )
.It Dv ok, errmsg, errcode = lzc.load_key(dsname , noop , wkey )
.It Dv ok, errmsg, errcode = lzc.unload_key(dsname )
.It Dv ok, errmsg, errcode = lzc.change_key(dsname , crypt_cmd[ , props[ , wkey ] ] )
.It Dv ok_or_errlist, errmsg, errcode = lzc.initialize(poolname , cmd_type , vdevs )
.It Dv ok_or_errlist, errmsg, errcode = lzc.trim(poolname , cmd_type , rate, secure , vdevs )
.It Dv ok, errmsg, errcode = lzc.redact(snapshot , bookmark , snaplist )
.It Dv used, errmsg, errcode = lzc.snaprange_space(firstsnap , lastsnap )
.It Dv ok_or_errlist, errmsg, errcode = lzc.hold(holds[ , cleanup_fd ] )
.It Dv ok_or_errlist, errmsg, errcode = lzc.release(holds )
.It Dv holds, errmsg, errcode = lzc.get_holds(snapname )
.It Dv props, errmsg, errcode = lzc.get_props(poolname )
.It Dv ok, errmsg, errcode = lzc.send(snapname , [from ] , fd[ , flags ] )
.It Dv ok, errmsg, errcode = lzc.send_resume(snapname , [from ] , fd , [flags ] , resumeobj , resumeoff )
.It Dv ok, errmsg, errcode = lzc.send_redacted(snapname , [from ] , fd[ , flags[ , redactbook ] ] )
.It Dv ok, errmsg, errcode = lzc.send_resume_redacted(snapname , [from ] , fd[ , resumeobj , resumeoff[ , redactbook ] ] )
.It Dv space, errmsg, errcode = lzc.send_space(snapname[ , from[ , flags ] ] )
.It Dv space, errmsg, errcode = lzc.send_space_resume_redacted(snapname[ , from[ , resumeobj , resumeoff , resume_bytes[ , redactbook[ , fd ] ] ] ] )
.It Dv bytes_written, blocks_visited_or_errmsg, errcode = lzc.send_progress(snapname , fd )
.It Dv ok, errmsg, errcode = lzc.receive(snapname , [props ] , [origin ] , force , raw , fd )
.It Dv ok, errmsg, errcode = lzc.receive_resumable(snapname , [props ] , [origin ] , force , raw , fd )
.It Dv exists = lzc.exists(dsname )
.It Dv snapname, errmsg, errcode = lzc.rollback(dsname )
.It Dv ok, errmsg, errcode = lzc.rollback_to(dsname , snapname )
.It Dv ok, errmsg, errcode = lzc.rename(source , target )
.It Dv ok, errmsg, errcode = lzc.destroy(dsname )
.It Dv ok_or_result, errmsg, errcode = lzc.channel_program(poolname , program , [instrlimit ] , [memlimit ] , arg )
.It Dv ok_or_result, errmsg, errcode = lzc.channel_program_nosync(poolname , program , [instrlimit ] , [memlimit ] , arg )
.It Dv ok_or_results, errmsg, errcode = lzc.sync(poolname[ , args ] )
.It Dv ok, errmsg, errcode = lzc.reopen(poolname[ , scrub_restart ] )
.It Dv ok, errmsg, errcode = lzc.pool_checkpoint(poolname )
.It Dv ok, errmsg, errcode = lzc.pool_checkpoint_discard(poolname )
.It Dv waited, errmsg, errcode = lzc.wait(poolname , activity )
.It Dv waited, errmsg, errcode = lzc.wait_tag(poolname , activity[ , tag ] )
.It Dv ok, errmsg, errcode = lzc.pool_prefetch(poolname , type )
.It Dv waited, errmsg, errcode = lzc.wait_fs(fsname , activity )
.It Dv ok, errmsg, errcode = lzc.set_bootenv(poolname , props )
.It Dv props, errmsg, errcode = lzc.get_bootenv(poolname )
.It Dv ok_or_result, errmsg, errcode = lzc.get_vdev_prop(poolname , args )
.It Dv ok_or_result, errmsg, errcode = lzc.set_vdev_prop(poolname , args )
.It Dv ok_or_result, errmsg, errcode = lzc.scrub(poolname , args )
.It Dv ok, errmsg, errcode = lzc.ddt_prune(poolname , unit , amount )
.It Dv lzc.LZC_DATSET_TYPE_ZFS
.It Dv lzc.LZC_DATSET_TYPE_ZVOL
.It Dv lzc.LZC_SEND_FLAG_EMBED_DATA
.It Dv lzc.LZC_SEND_FLAG_LARGE_BLOCK
.It Dv lzc.LZC_SEND_FLAG_COMPRESS
.It Dv lzc.LZC_SEND_FLAG_RAW
.It Dv lzc.LZC_SEND_FLAG_SAVED
.It Dv lzc.POOL_INITIALIZE_START
.It Dv lzc.POOL_INITIALIZE_CANCEL
.It Dv lzc.POOL_INITIALIZE_SUSPEND
.It Dv lzc.POOL_INITIALIZE_UNINIT
.It Dv lzc.POOL_INITIALIZE_FUNCS
.It Dv lzc.POOL_TRIM_START
.It Dv lzc.POOL_TRIM_CANCEL
.It Dv lzc.POOL_TRIM_SUSPEND
.It Dv lzc.POOL_TRIM_FUNCS
.It Dv lzc.ZPOOL_WAIT_CKPT_DISCARD
.It Dv lzc.ZPOOL_WAIT_FREE
.It Dv lzc.ZPOOL_WAIT_INITIALIZE
.It Dv lzc.ZPOOL_WAIT_REPLACE
.It Dv lzc.ZPOOL_WAIT_REMOVE
.It Dv lzc.ZPOOL_WAIT_RESILVER
.It Dv lzc.ZPOOL_WAIT_SCRUB
.It Dv lzc.ZPOOL_WAIT_TRIM
.It Dv lzc.ZPOOL_WAIT_RAIDZ_EXPAND
.It Dv lzc.ZPOOL_WAIT_NUM_ACTIVITIES
.It Dv lzc.ZFS_WAIT_DELETEQ
.It Dv lzc.ZFS_WAIT_NUM_ACTIVITIES
.It Dv lzc.ZPOOL_PREFETCH_NONE
.It Dv lzc.ZPOOL_PREFETCH_DDT
.It Dv lzc.ZPOOL_PREFETCH_BRT
.It Dv lzc.ZPOOL_DDT_PRUNE_NONE
.It Dv lzc.ZPOOL_DDT_PRUNE_AGE
.It Dv lzc.ZPOOL_DDT_PRUNE_PERCENTAGE
.El
.Sh DESCRIPTION
The
.Nm
module provides bindings for OpenZFS libzfs_core
.Pq 3
function calls.
.Pp
The functions in this module return errors from libzfs_core to the caller.
.Bl -tag -width XXXX
