.Sh EXAMPLES
Get properties of a dataset:
.Bd -literal -offset indent
libzfs = require('zfs').init()

fs = libzfs:open('zroot', libzfs.ZFS_TYPE_FILESYSTEM)
props = fs:get_all_props()
for _, name, value in pairs(props) do
	print(name, value:lookup('value'))
end
.Ed
